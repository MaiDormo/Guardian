# Ollama — must be running on host before `docker compose up`
# Run: ollama pull gemma4:e4b && ollama pull nomic-embed-text
OLLAMA_HOST=http://localhost:11434

# SQLite database path (Tanmay's module)
DB_PATH=./guardian.db

# WhatsApp Business API (optional — overlay renders regardless if missing)
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
CAREGIVER_PHONE=+852XXXXXXXXXX

# Backend URL used by radar_simulator.py
BACKEND_URL=http://localhost:8000
