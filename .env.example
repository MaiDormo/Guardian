# Ollama — must be running on host before `docker compose up`
# Run: ollama pull gemma4:e4b && ollama pull nomic-embed-text
OLLAMA_HOST=http://localhost:11434

# SQLite database path (Tanmay's module)
DB_PATH=./guardian.db

# Schema migrations run automatically on backend startup (Alembic).
# Manual: cd backend && python migrate.py upgrade
# Backup:  cd backend && python backup.py create
# Restore: cd backend && python backup.py restore --from backups/guardian_....db --yes

# ── WeChat / WeCom (PRIMARY — recommended for GBA / mainland China caregivers) ──
# Setup (2 minutes):
#   1. Open WeChat Work (企业微信) → open or create a group
#   2. Group settings → "群机器人" (Group Bot) → Add Bot → name it "Guardian"
#   3. Copy the webhook URL and paste it below
#   4. The caregiver only needs WeChat Work installed — free, no business registration
# Alternative: WxPusher (personal WeChat, free) — https://wxpusher.zjiecode.com
# Paste your real webhook URL — dashboard shows "WeCom dispatch ready" when set.
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY_HERE

# ── WhatsApp Business API (FALLBACK — for HK-side family contacts) ──
# Requires Meta business account + verified phone number. Skipped if WECOM_WEBHOOK_URL is set.
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
CAREGIVER_PHONE=+852XXXXXXXXXX

# Backend URL used by radar_simulator.py
BACKEND_URL=http://localhost:8000

# Frontend: simplified Reasoning Console for stage (default on). Set false for full XML Devpost screenshots.
# NEXT_PUBLIC_REASONING_DEMO_MODE=false

# Auto-dispatch caregiver alert when fall_detected fires (safety-reflex tier)
AUTO_DISPATCH_ON_FALL=true

# Append UUID to dedup keys so replay tests against a persistent SQLite DB never collide
DEDUP_TEST_MODE=false
